.PHONY: help install install-dev test format lint clean run-exampleshelp:	@echo "Available targets:"	@echo "  install      Install dependencies"	@echo "  install-dev  Install development dependencies"	@echo "  test         Run tests"	@echo "  format       Format code with black and isort"	@echo "  lint         Run linting with flake8"	@echo "  clean        Clean up cache files"	@echo "  run-examples List and run available examples"install:	pip install -r requirements.txtinstall-dev:	pip install -e ".[dev]"test:	pytest tests/format:	black src/ examples/ tests/	isort src/ examples/ tests/lint:	flake8 src/ examples/ tests/	mypy src/clean:	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true	find . -type f -name "*.pyc" -delete	rm -rf .pytest_cache/	rm -rf build/	rm -rf dist/	rm -rf *.egg-info/run-examples:	@echo "Available examples:"	@echo "  python examples/text_messaging.py"	@echo "  python examples/multimodal_messaging.py"	@echo "  python examples/round_robin_agents.py"	@echo "  python examples/round_robin_with_human.py"	@echo "  python examples/state_saving.py"	@echo "  python examples/selector_group_chat.py"	@echo "  python examples/multimodal_web_surfer.py"	@echo "  python examples/tooling_example.py"	@echo "  python examples/jira_scenario.py"